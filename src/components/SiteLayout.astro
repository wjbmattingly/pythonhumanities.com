---
import "../styles/global.css";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import { url } from "../lib/url";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title = "Python for Digital Humanities",
  description = "Free textbooks, video lessons, and a full course teaching Python to humanists, sociologists, and researchers. By Dr. William Mattingly.",
  canonical,
  ogImage,
} = Astro.props;

const fullTitle = title === "Python for Digital Humanities"
  ? title
  : `${title} — Python for Digital Humanities`;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site ?? "https://pythonhumanities.com").toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@wjb_mattingly" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300..700&family=Source+Serif+4:opsz,wght@8..60,300..700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <link rel="icon" href={url("/favicon.svg")} type="image/svg+xml" />
    <meta name="theme-color" content="#f5efe3" />
  </head>
  <body>
    <a href="#main" class="sr-only">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
