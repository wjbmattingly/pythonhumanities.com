---
import { url, withoutBase } from "../lib/url";
const pathname = withoutBase(Astro.url.pathname);
const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
};
const links = [
  { href: "/", label: "Home" },
  { href: "/textbooks/", label: "Textbooks" },
  { href: "/videos/", label: "Videos" },
  { href: "/course/", label: "Course" },
  { href: "/about/", label: "About" },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a href={url("/")} class="brand" aria-label="Python for Digital Humanities — home">
      <span class="brand-mark" aria-hidden="true">
        <svg viewBox="0 0 64 64" width="44" height="44">
          <circle cx="32" cy="32" r="29.5" fill="none" stroke="currentColor" stroke-width="1.4"/>
          <circle cx="32" cy="32" r="26" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.5"/>
          <text x="32" y="40.5"
            font-family="var(--font-display)"
            font-size="20"
            font-weight="500"
            font-style="italic"
            text-anchor="middle"
            fill="currentColor">PyDH</text>
        </svg>
      </span>
      <span class="brand-text">
        <span class="brand-title">Python for</span>
        <span class="brand-subtitle">Digital Humanities</span>
      </span>
    </a>
    <nav aria-label="Primary">
      <ul class="nav-list">
        {links.map((link) => (
          <li>
            <a
              href={url(link.href)}
              class:list={["nav-link", { active: isActive(link.href) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
        <li>
          <button
            type="button"
            class="theme-toggle"
            aria-label="Toggle dark mode"
            data-theme-toggle
          >
            <svg class="theme-icon icon-sun" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
              <circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.6"/>
              <g stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
                <line x1="12" y1="2.5" x2="12" y2="5"/>
                <line x1="12" y1="19" x2="12" y2="21.5"/>
                <line x1="2.5" y1="12" x2="5" y2="12"/>
                <line x1="19" y1="12" x2="21.5" y2="12"/>
                <line x1="5.2" y1="5.2" x2="6.9" y2="6.9"/>
                <line x1="17.1" y1="17.1" x2="18.8" y2="18.8"/>
                <line x1="5.2" y1="18.8" x2="6.9" y2="17.1"/>
                <line x1="17.1" y1="6.9" x2="18.8" y2="5.2"/>
              </g>
            </svg>
            <svg class="theme-icon icon-moon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
              <path
                d="M20.5 14.2A8.5 8.5 0 0 1 9.8 3.5a8.5 8.5 0 1 0 10.7 10.7Z"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linejoin="round"
              />
            </svg>
          </button>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    var btn = document.querySelector("[data-theme-toggle]");
    if (!btn) return;
    function current() {
      var explicit = document.documentElement.getAttribute("data-theme");
      if (explicit) return explicit;
      return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
    }
    btn.addEventListener("click", function () {
      var next = current() === "dark" ? "light" : "dark";
      document.documentElement.setAttribute("data-theme", next);
      try {
        localStorage.setItem("theme", next);
      } catch (_) {}
    });
  })();
</script>

<style>
  .site-header {
    border-bottom: 1px solid var(--rule);
    background: var(--parchment);
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: saturate(1.2);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
    padding-block: var(--space-4);
    flex-wrap: wrap;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    color: var(--ink);
  }

  .brand:hover { color: var(--oxblood); }

  .brand-mark {
    color: var(--oxblood);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  .brand-mark svg text {
    font-family: var(--font-display), Georgia, serif;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .brand-title {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--ink-muted);
    font-weight: 400;
  }

  .brand-subtitle {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--ink);
    font-variation-settings: "opsz" 72;
  }

  nav { display: flex; }

  .nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  .nav-list li { margin: 0; }

  .nav-link {
    text-decoration: none;
    color: var(--ink-soft);
    font-family: var(--font-sans);
    font-size: 0.92rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    padding-block: var(--space-1);
    border-bottom: 1.5px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .nav-link:hover {
    color: var(--oxblood);
    border-bottom-color: var(--oxblood);
  }

  .nav-link.active {
    color: var(--oxblood);
    border-bottom-color: var(--gold);
  }

  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    border: 1px solid var(--rule);
    background: transparent;
    color: var(--ink-soft);
    border-radius: 999px;
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }

  .theme-toggle:hover {
    color: var(--oxblood);
    border-color: var(--oxblood);
  }

  .theme-icon { display: none; }
  :global(:root[data-theme="light"]) .icon-moon { display: block; }
  :global(:root[data-theme="dark"]) .icon-sun { display: block; }

  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme])) .icon-sun { display: block; }
  }
  @media (prefers-color-scheme: light) {
    :global(:root:not([data-theme])) .icon-moon { display: block; }
  }

  @media (max-width: 720px) {
    .brand-title { display: none; }
    .brand-subtitle { font-size: 1rem; }
    .nav-list { gap: var(--space-4); }
    .nav-link { font-size: 0.88rem; }
  }
</style>
