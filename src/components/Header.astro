---
const pathname = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
};
const links = [
  { href: "/", label: "Home" },
  { href: "/textbooks/", label: "Textbooks" },
  { href: "/videos/", label: "Videos" },
  { href: "/course/", label: "Course" },
  { href: "/blog/", label: "Blog" },
  { href: "/about/", label: "About" },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="Python for Digital Humanities — home">
      <span class="brand-mark">π</span>
      <span class="brand-text">
        <span class="brand-title">Python for</span>
        <span class="brand-subtitle">Digital Humanities</span>
      </span>
    </a>
    <nav aria-label="Primary">
      <ul class="nav-list">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={["nav-link", { active: isActive(link.href) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--rule);
    background: var(--parchment);
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: saturate(1.2);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
    padding-block: var(--space-4);
    flex-wrap: wrap;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    color: var(--ink);
  }

  .brand:hover { color: var(--oxblood); }

  .brand-mark {
    font-family: var(--font-display);
    font-size: 1.9rem;
    color: var(--oxblood);
    font-weight: 400;
    line-height: 1;
    border: 1.5px solid var(--oxblood);
    border-radius: 50%;
    width: 2.3rem;
    height: 2.3rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding-bottom: 0.2em;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .brand-title {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--ink-muted);
    font-weight: 400;
  }

  .brand-subtitle {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--ink);
    font-variation-settings: "opsz" 72;
  }

  nav { display: flex; }

  .nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  .nav-list li { margin: 0; }

  .nav-link {
    text-decoration: none;
    color: var(--ink-soft);
    font-family: var(--font-sans);
    font-size: 0.92rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    padding-block: var(--space-1);
    border-bottom: 1.5px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .nav-link:hover {
    color: var(--oxblood);
    border-bottom-color: var(--oxblood);
  }

  .nav-link.active {
    color: var(--oxblood);
    border-bottom-color: var(--gold);
  }

  @media (max-width: 720px) {
    .brand-title { display: none; }
    .brand-subtitle { font-size: 1rem; }
    .nav-list { gap: var(--space-4); }
    .nav-link { font-size: 0.88rem; }
  }
</style>
