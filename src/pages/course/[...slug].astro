---
import SiteLayout from "../../components/SiteLayout.astro";
import VideoEmbed from "../../components/VideoEmbed.astro";
import PythonPlayground from "../../components/PythonPlayground.astro";
import { getCollection, render } from "astro:content";
import { url } from "../../lib/url";

export async function getStaticPaths() {
  const lessons = await getCollection("course");
  return lessons.map((lesson) => ({
    params: { slug: lesson.id },
    props: { lesson },
  }));
}

const { lesson } = Astro.props;
const { Content } = await render(lesson);

const all = (await getCollection("course")).sort(
  (a, b) => a.data.lessonNumber - b.data.lessonNumber
);
const idx = all.findIndex((l) => l.id === lesson.id);
const prev = idx > 0 ? all[idx - 1] : undefined;
const next = idx < all.length - 1 ? all[idx + 1] : undefined;

const partsMap = new Map<number, { number: number; title: string; lessons: typeof all }>();
for (const l of all) {
  let p = partsMap.get(l.data.part);
  if (!p) {
    p = { number: l.data.part, title: l.data.partTitle, lessons: [] };
    partsMap.set(l.data.part, p);
  }
  p.lessons.push(l);
}
const parts = [...partsMap.values()].sort((a, b) => a.number - b.number);
---

<SiteLayout title={lesson.data.title} description={lesson.data.description}>
  <article class="lesson container">
    <aside class="lesson-toc" aria-label="All lessons">
      <div class="toc-inner">
        <p class="toc-eyebrow">Course</p>
        <h2 class="toc-title">
          <a href={url("/course/")}>Python for DH</a>
        </h2>
        <details class="toc-collapse" open>
          <summary>
            <span class="toc-collapse-label">Course outline</span>
            <span class="toc-collapse-current">{`Lesson ${String(lesson.data.lessonNumber).padStart(2, "0")} — ${lesson.data.title}`}</span>
            <span class="toc-collapse-chevron" aria-hidden="true">▾</span>
          </summary>
          <nav class="toc-nav">
            {parts.map((part) => (
              <section class="toc-part">
                <p class="toc-part-label">
                  <span class="toc-part-num">Part {String(part.number).padStart(2, "0")}</span>
                  <span class="toc-part-title">{part.title}</span>
                </p>
                <ol class="toc-lessons">
                  {part.lessons.map((l) => (
                    <li class:list={["toc-item", { current: l.id === lesson.id }]}>
                      <a href={url(`/course/${l.id}/`)}>
                        <span class="toc-num">{String(l.data.lessonNumber).padStart(2, "0")}</span>
                        <span class="toc-text">{l.data.title}</span>
                      </a>
                    </li>
                  ))}
                </ol>
              </section>
            ))}
          </nav>
        </details>
        <script is:inline>
          if (window.matchMedia("(max-width: 980px)").matches) {
            document.currentScript.previousElementSibling?.removeAttribute("open");
          }
        </script>
      </div>
    </aside>

    <div class="lesson-main">
      <header class="lesson-header">
        <p class="breadcrumb">
          <a href={url("/course/")}>Course</a>
          <span aria-hidden="true"> · </span>
          <span>Part {String(lesson.data.part).padStart(2, "0")} — {lesson.data.partTitle}</span>
        </p>
        <p class="lesson-num">Lesson {String(lesson.data.lessonNumber).padStart(2, "0")}</p>
        <h1>{lesson.data.title}</h1>
        {lesson.data.description && <p class="lede">{lesson.data.description}</p>}
      </header>

      <div class="lesson-body">
        <div class="prose-content">
          {lesson.data.videoId && (
            <VideoEmbed videoId={lesson.data.videoId} title={lesson.data.title} />
          )}
          <Content />
        </div>
      </div>

      <nav class="lesson-nav" aria-label="Lesson navigation">
        {prev ? (
          <a href={url(`/course/${prev.id}/`)} class="nav-link prev">
            <span class="nav-kicker">← Previous</span>
            <span class="nav-title">{prev.data.title}</span>
          </a>
        ) : <span />}
        {next ? (
          <a href={url(`/course/${next.id}/`)} class="nav-link next">
            <span class="nav-kicker">Next →</span>
            <span class="nav-title">{next.data.title}</span>
          </a>
        ) : <span />}
      </nav>
    </div>
  </article>
  <PythonPlayground />
</SiteLayout>

<style>
  .lesson {
    display: grid;
    grid-template-columns: 18rem minmax(0, 1fr);
    gap: var(--space-7);
    padding-block: var(--space-7) var(--space-7);
    align-items: start;
  }

  .lesson-toc {
    position: sticky;
    top: 5rem;
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
    padding-right: var(--space-4);
    border-right: 1px solid var(--rule);
  }

  .toc-inner {
    display: flex;
    flex-direction: column;
  }

  .toc-collapse {
    margin: 0;
  }

  .toc-collapse > summary {
    display: none;
    list-style: none;
    cursor: pointer;
  }

  .toc-collapse > summary::-webkit-details-marker {
    display: none;
  }

  .toc-collapse-label,
  .toc-collapse-current,
  .toc-collapse-chevron {
    display: none;
  }

  .toc-collapse > .toc-nav {
    display: block;
  }

  .toc-eyebrow {
    font-family: var(--font-display);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--gold-dark);
    margin: 0 0 var(--space-1);
    font-weight: 500;
  }

  .toc-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    margin: 0 0 var(--space-5);
    font-variation-settings: "opsz" 72;
  }

  .toc-title a {
    color: var(--ink);
    text-decoration: none;
  }
  .toc-title a:hover { color: var(--oxblood); }

  .toc-part {
    margin-bottom: var(--space-5);
  }

  .toc-part-label {
    margin: 0 0 var(--space-2);
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .toc-part-num {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-muted);
  }

  .toc-part-title {
    font-family: var(--font-display);
    font-size: 0.98rem;
    font-weight: 500;
    color: var(--ink);
    font-variation-settings: "opsz" 72;
  }

  .toc-lessons {
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: 1px solid var(--rule-soft);
  }

  .toc-item { margin: 0; }

  .toc-item a {
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: var(--space-2);
    padding: 0.32rem var(--space-3);
    text-decoration: none;
    color: var(--ink-soft);
    font-size: 0.88rem;
    line-height: 1.35;
    border-left: 2px solid transparent;
    margin-left: -1px;
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }

  .toc-item a:hover {
    color: var(--oxblood);
    background: var(--parchment-light);
  }

  .toc-num {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    color: var(--ink-muted);
    letter-spacing: 0.04em;
    padding-top: 0.12rem;
  }

  .toc-text {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 18;
  }

  .toc-item.current a {
    color: var(--oxblood);
    border-left-color: var(--gold);
    font-weight: 600;
    background: var(--parchment-light);
  }

  .toc-item.current .toc-num { color: var(--oxblood); }

  .lesson-main {
    min-width: 0;
  }

  .lesson-header {
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--rule);
    margin-bottom: var(--space-6);
  }

  .breadcrumb {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--ink-muted);
    margin: 0 0 var(--space-3);
  }

  .breadcrumb a {
    color: var(--ink-muted);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--oxblood);
    text-decoration: underline;
  }

  .lesson-num {
    font-family: var(--font-display);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--gold-dark);
    margin: 0 0 var(--space-2);
    font-weight: 500;
  }

  .lesson .lede {
    font-size: 1.2rem;
    color: var(--ink-soft);
    line-height: 1.55;
    max-width: 58ch;
    margin-top: var(--space-3);
  }

  .prose-content {
    max-width: var(--measure);
  }

  .prose-content :global(h2) {
    margin-top: var(--space-7);
    padding-top: var(--space-5);
    border-top: 1px solid var(--rule-soft);
  }

  .prose-content :global(h2:first-child) {
    border-top: none;
    padding-top: 0;
    margin-top: 0;
  }

  .prose-content :global(img) {
    border: 1px solid var(--rule);
    border-radius: 4px;
    margin-block: var(--space-5);
  }

  .lesson-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    padding-block: var(--space-5);
    margin-top: var(--space-6);
    border-top: 1px solid var(--rule);
  }

  .nav-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--rule);
    border-radius: 4px;
    text-decoration: none;
    color: var(--ink);
    background: var(--parchment-light);
    transition: border-color 0.15s ease;
  }

  .nav-link:hover {
    border-color: var(--gold);
    color: var(--ink);
  }

  .nav-link.next {
    text-align: right;
  }

  .nav-kicker {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--ink-muted);
    letter-spacing: 0.05em;
  }

  .nav-title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 500;
    font-variation-settings: "opsz" 72;
  }

  @media (max-width: 980px) {
    .lesson {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
    .lesson-toc {
      position: static;
      max-height: none;
      overflow: visible;
      padding-right: 0;
      border-right: none;
      border-bottom: 1px solid var(--rule);
      padding-bottom: var(--space-4);
    }

    .toc-eyebrow,
    .toc-title {
      display: none;
    }

    .toc-collapse > summary {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: var(--space-3);
      padding: var(--space-3) var(--space-4);
      background: var(--parchment-light);
      border: 1px solid var(--rule);
      border-radius: 4px;
      transition: border-color 0.15s ease, background 0.15s ease;
    }

    .toc-collapse > summary:hover {
      border-color: var(--gold);
    }

    .toc-collapse-label {
      display: inline;
      font-family: var(--font-sans);
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--gold-dark);
      font-weight: 500;
    }

    .toc-collapse-current {
      display: inline;
      font-family: var(--font-display);
      font-size: 0.95rem;
      color: var(--ink);
      font-variation-settings: "opsz" 32;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      min-width: 0;
    }

    .toc-collapse-chevron {
      display: inline-block;
      color: var(--ink-muted);
      transition: transform 0.2s ease;
    }

    .toc-collapse[open] > summary .toc-collapse-chevron {
      transform: rotate(180deg);
    }

    .toc-collapse:not([open]) > .toc-nav {
      display: none;
    }

    .toc-collapse[open] > .toc-nav {
      display: block;
      padding-top: var(--space-4);
    }
  }

  @media (max-width: 620px) {
    .lesson-nav { grid-template-columns: 1fr; }
    .nav-link.next { text-align: left; }
  }
</style>
