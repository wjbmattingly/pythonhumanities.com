---
import SiteLayout from "../../components/SiteLayout.astro";
import VideoEmbed from "../../components/VideoEmbed.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const lessons = await getCollection("course");
  return lessons.map((lesson) => ({
    params: { slug: lesson.id },
    props: { lesson },
  }));
}

const { lesson } = Astro.props;
const { Content } = await render(lesson);

const all = (await getCollection("course")).sort(
  (a, b) => a.data.lessonNumber - b.data.lessonNumber
);
const idx = all.findIndex((l) => l.id === lesson.id);
const prev = idx > 0 ? all[idx - 1] : undefined;
const next = idx < all.length - 1 ? all[idx + 1] : undefined;
---

<SiteLayout title={lesson.data.title} description={lesson.data.description}>
  <article class="lesson">
    <header class="lesson-header container">
      <p class="breadcrumb">
        <a href="/course/">Course</a>
        <span aria-hidden="true"> · </span>
        <span>Part {String(lesson.data.part).padStart(2, "0")} — {lesson.data.partTitle}</span>
      </p>
      <p class="lesson-num">Lesson {String(lesson.data.lessonNumber).padStart(2, "0")}</p>
      <h1>{lesson.data.title}</h1>
      {lesson.data.description && <p class="lede">{lesson.data.description}</p>}
    </header>

    <div class="container lesson-body">
      <div class="prose-content">
        {lesson.data.videoId && (
          <VideoEmbed videoId={lesson.data.videoId} title={lesson.data.title} />
        )}
        <Content />
      </div>
    </div>

    <nav class="lesson-nav container" aria-label="Lesson navigation">
      {prev ? (
        <a href={`/course/${prev.id}/`} class="nav-link prev">
          <span class="nav-kicker">← Previous</span>
          <span class="nav-title">{prev.data.title}</span>
        </a>
      ) : <span />}
      {next ? (
        <a href={`/course/${next.id}/`} class="nav-link next">
          <span class="nav-kicker">Next →</span>
          <span class="nav-title">{next.data.title}</span>
        </a>
      ) : <span />}
    </nav>
  </article>
</SiteLayout>

<style>
  .lesson-header {
    padding-block: var(--space-7) var(--space-5);
    border-bottom: 1px solid var(--rule);
  }

  .breadcrumb {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--ink-muted);
    margin: 0 0 var(--space-3);
  }

  .breadcrumb a {
    color: var(--ink-muted);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--oxblood);
    text-decoration: underline;
  }

  .lesson-num {
    font-family: var(--font-display);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--gold-dark);
    margin: 0 0 var(--space-2);
    font-weight: 500;
  }

  .lesson .lede {
    font-size: 1.2rem;
    color: var(--ink-soft);
    line-height: 1.55;
    max-width: 58ch;
    margin-top: var(--space-3);
  }

  .lesson-body {
    padding-block: var(--space-6);
  }

  .prose-content {
    max-width: var(--measure);
  }

  .prose-content :global(h2) {
    margin-top: var(--space-7);
    padding-top: var(--space-5);
    border-top: 1px solid var(--rule-soft);
  }

  .prose-content :global(h2:first-child) {
    border-top: none;
    padding-top: 0;
    margin-top: 0;
  }

  .prose-content :global(img) {
    border: 1px solid var(--rule);
    border-radius: 4px;
    margin-block: var(--space-5);
  }

  .lesson-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    padding-block: var(--space-5);
    margin-top: var(--space-6);
    border-top: 1px solid var(--rule);
  }

  .nav-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--rule);
    border-radius: 4px;
    text-decoration: none;
    color: var(--ink);
    background: var(--parchment-light);
    transition: border-color 0.15s ease;
  }

  .nav-link:hover {
    border-color: var(--gold);
    color: var(--ink);
  }

  .nav-link.next {
    text-align: right;
  }

  .nav-kicker {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--ink-muted);
    letter-spacing: 0.05em;
  }

  .nav-title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 500;
    font-variation-settings: "opsz" 72;
  }

  @media (max-width: 620px) {
    .lesson-nav { grid-template-columns: 1fr; }
    .nav-link.next { text-align: left; }
  }
</style>
